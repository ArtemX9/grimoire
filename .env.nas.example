# NAS network
NAS_IP=192.168.1.100        # your NAS local IP
APP_PORT=8080               # port to access the app (avoid 80 — UGOS uses it)

# Database
POSTGRES_USER=grimoire
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=grimoire

# Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string

# Steam (optional)
STEAM_API_KEY=

# IGDB / Twitch (optional)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# LLM — pick one: grok | claude
LLM_PROVIDER=grok
GROK_API_KEY=
ANTHROPIC_API_KEY=
