generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  name               String?
  plan               Plan                 @default(FREE)
  role               Role                 @default(USER)
  passwordHash       String?
  mustChangePassword Boolean              @default(false)
  isDemo             Boolean              @default(false)
  aiEnabled          Boolean              @default(true)
  aiRequestsUsed     Int                  @default(0)
  aiRequestsLimit    Int?
  stripeId           String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  emailVerified      Boolean              @default(false)
  image              String?
  games              UserGame[]
  sessions           PlaySession[]
  platforms          UserPlatform[]
  accounts           Account[]
  authSessions       Session[]
  unmappedSyncedGame UnmappedSyncedGame[]
}

// Better Auth required models
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
}

enum Plan {
  FREE
  PRO
  LIFETIME
}

enum Role {
  ADMIN
  USER
}

model AiGlobalSettings {
  id        Int     @id @default(1)
  aiEnabled Boolean @default(true)
}

model UserGame {
  id                String             @id @default(cuid())
  userId            String
  igdbGameId        String
  status            GameStatus         @default(BACKLOG)
  playtimeHours     Float              @default(0)
  userRating        Int?
  notes             String?
  moods             String[]
  addedAt           DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isMappedManually  Boolean            @default(false)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  igdbGame          IGDBGame           @relation(fields: [igdbGameId], references: [id], onDelete: Cascade)
  sessions          PlaySession[]
  userGamePlatforms UserGamePlatform[]

  @@unique([userId, igdbGameId])
  @@index([userId, status])
}

enum GameStatus {
  BACKLOG
  PLAYING
  COMPLETED
  DROPPED
  WISHLIST
}

model PlaySession {
  id          String   @id @default(cuid())
  userId      String
  gameId      String
  startedAt   DateTime
  durationMin Int?
  mood        String[]
  notes       String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game        UserGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([userId, gameId])
}

model UserPlatform {
  id           String    @id @default(cuid())
  userId       String
  platformId   Int
  externalId   String
  accessToken  String?
  refreshToken String?
  lastSyncAt   DateTime?
  isSyncing    Boolean?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     Platforms @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([userId, platformId])
}

model Platforms {
  id              Int               @id @default(autoincrement())
  platform        PlatformTitle
  userPlatforms   UserPlatform[]
  syncedGames     SyncedGame[]
  platformsTokens PlatformsTokens?

  @@unique([platform])
}

model PlatformsTokens {
  id        Int       @id
  token     String
  dateFrame Int
  dateSet   DateTime
  platform  Platforms @relation(fields: [id], references: [id], onDelete: Cascade)
}

enum PlatformTitle {
  STEAM
  PlayStation
  Xbox
  PC
}

model IGDBGame {
  id                 String               @id @default(cuid())
  igdbId             Int
  title              String
  coverUrl           String?
  genres             String[]
  summary            String?
  storyLine          String?
  themes             String[]
  releaseDate        DateTime?
  updatedAt          DateTime             @updatedAt
  userGames          UserGame[]
  unmappedSyncedGame UnmappedSyncedGame[]

  @@unique([igdbId])
}

model SyncedGame {
  id                 String               @id @default(cuid())
  platformId         Int
  externalId         String
  externalTitle      String
  coverUrl           String?
  summary            String?
  platform           Platforms            @relation(fields: [platformId], references: [id])
  userGamePlatforms  UserGamePlatform[]
  unmappedSyncedGame UnmappedSyncedGame[]

  @@unique([platformId, externalId])
}

enum UnmappedReason {
  DUPLICATE_MATCH
  LOW_CONFIDENCE
  NO_MATCH
  USER_DELETED
}

model UnmappedSyncedGame {
  id            String         @id @default(cuid())
  syncedGameId  String
  userId        String
  reason        UnmappedReason
  playtimeHours Float          @default(0)
  isMapped      Boolean        @default(false)
  igdbGameId    Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncedGame    SyncedGame     @relation(fields: [syncedGameId], references: [id], onDelete: Cascade)
  igdbGame      IGDBGame?      @relation(fields: [igdbGameId], references: [igdbId], onDelete: SetNull, onUpdate: SetNull)

  @@unique([userId, syncedGameId])
}

model UserGamePlatform {
  id           String     @id @default(cuid())
  userGameId   String
  syncedGameId String
  userGame     UserGame   @relation(fields: [userGameId], references: [id], onDelete: Cascade)
  syncedGame   SyncedGame @relation(fields: [syncedGameId], references: [id], onDelete: Cascade)

  @@unique([userGameId, syncedGameId])
}
