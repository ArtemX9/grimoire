# App
PORT=3000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grimoire

# Redis
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:5173

# Crypto — AES-256-GCM key for encrypting stored OAuth tokens (openssl rand -hex 32)
ENCRYPTION_KEY=

# Steam
STEAM_API_KEY=

# Playstation
PSN_NPSSO=

# Xbox — register an app at https://portal.azure.com (Supported account types: "Personal Microsoft accounts only")
# Redirect URI must match what is configured in the Azure app registration
XBOX_CLIENT_ID=
XBOX_CLIENT_SECRET=
XBOX_REDIRECT_URI=http://localhost:3000/api/v1/platforms/xbox/connect/callback
XBOX_FRONTEND_REDIRECT_URI=http://localhost:5173/settings?tab=platforms

# IGDB (Twitch App credentials)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# LLM
LLM_PROVIDER=grok
# grok | claude | openai | ollama
GROK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Tuning — applies to all providers
LLM_TEMPERATURE=0.7
LLM_NUM_CTX=32768
